rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Docs de la colección principal de bodegas
    match /warehouses/{warehouseId} {
      allow read, write: if request.auth != null;
    }

    // Cualquier subcolección dentro de una bodega (ej. state/main)
    match /warehouses/{warehouseId}/{col}/{doc} {
      allow read, write: if request.auth != null;
    }

    // Clients catalog managed by rol configurador
    match /clientes/{clientId} {
      allow read, write: if request.auth != null;
    }

    match /clientes/{clientId}/ordenesCompra/{ordenId} {
      allow read, write: if request.auth != null;
    }

    match /clientes/{clientId}/solicitudesCompra/{solicitudId} {
      allow read, write: if request.auth != null;
    }

    // Usuarios de configuración (separados del perfil auth /users)
    match /usuarios/{userId} {
      allow read, write: if request.auth != null;
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Tareas de cuenta → configurador (subcolección: entra en clientes/.../{document=**} si usás regla recursiva)
    match /clientes/{clientId}/tareasParaConfigurador/{tareaId} {
      allow read, write: if request.auth != null;
    }
  }
}
