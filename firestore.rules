rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Docs de la colección principal de bodegas
    match /warehouses/{warehouseId} {
      allow read, write: if request.auth != null;
    }

    // Cualquier subcolección dentro de una bodega (ej. state/main)
    match /warehouses/{warehouseId}/{col}/{doc} {
      allow read, write: if request.auth != null;
    }

    // Documento raíz del cliente
    match /clientes/{clientId} {
      allow read, write: if request.auth != null;
    }

    /**
     * Toda ruta bajo clientes/{clientId}/… (productos, ordenesCompra, solicitudesProcesamiento,
     * ordenesVenta/…/viajesTransporte, etc.). Evita olvidar una subcolección en reglas nuevas.
     */
    match /clientes/{clientId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Usuarios de configuración (separados del perfil auth /users)
    match /usuarios/{userId} {
      allow read, write: if request.auth != null;
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    /** Contador global para números de viaje TV-#### (único en todo el sistema). */
    match /systemCounters/{counterId} {
      allow read, write: if request.auth != null;
    }
  }
}
